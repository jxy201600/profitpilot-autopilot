{
  "name": "profitpilot-autopilot",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Qwen Cloud Autopilot Agent for small-business inquiry-to-quote workflows.",
  "license": "MIT",
  "scripts": {
    "demo": "node src/cli.mjs --sample examples/sample-inquiry.en.txt --out out/demo",
    "demo:zh": "node src/cli.mjs --sample examples/sample-inquiry.zh.txt --out out/demo-zh",
    "score": "node scripts/score-demo.mjs out/demo/result.json",
    "live:config": "node scripts/check-live-config.mjs",
    "live:smoke": "node scripts/qwen-live-smoke.mjs",
    "live:proof": "node scripts/export-live-proof.mjs",
    "deployment:proof": "node scripts/export-deployment-proof.mjs",
    "submission:bundle": "node scripts/build-submission-bundle.mjs",
    "devpost:fields": "node scripts/export-devpost-fields.mjs",
    "demo:storyboard": "node scripts/build-demo-storyboard.mjs",
    "demo:video": "node scripts/render-demo-video.mjs",
    "validate": "npm run check && npm test && npm run demo && npm run demo:zh && npm run score && npm run live:smoke && npm run deployment:proof && npm run submission:bundle && npm run devpost:fields && npm run demo:storyboard && node scripts/validate-submission.mjs",
    "start": "node src/server.mjs",
    "test": "node --test test/*.test.mjs",
    "check": "node scripts/check-syntax.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
